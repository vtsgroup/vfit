{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://iapersonal.app.br",
          "https://vfit.pages.dev",
          "http://localhost:3000"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["Content-Length", "Content-Type", "Content-Range", "ETag"],
      "maxAgeSeconds": 86400
    }
  ]
}
