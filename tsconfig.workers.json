{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@config/*": ["./config/*"],
      "@lib/*": ["./lib/*"],
      "@workers/*": ["./workers/*"]
    }
  },
  "include": [
    "workers/**/*.ts",
    "lib/**/*.ts",
    "config/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src",
    ".next"
  ]
}
