{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "deploy-vfit-patch-no-whatsapp",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/cf-deploy.js",
				"patch",
				"--allow-no-whatsapp"
			],
			"isBackground": false
		},
		{
			"label": "deploy-vfit-fast-no-build-no-whatsapp",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/cf-deploy.js",
				"patch",
				"--skip-build",
				"--skip-bump",
				"--skip-workers",
				"--skip-git",
				"--allow-no-whatsapp"
			],
			"isBackground": false
		}
	]
}