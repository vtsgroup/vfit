# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_NAME=VFIT
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787

# ============================================
# Cloudflare
# ============================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ============================================
# Database (Neon PostgreSQL)
# ============================================
NEON_DATABASE_URL=postgresql://user:password@xxx.neon.tech/vfit

# ============================================
# Auth
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/oauth/google/callback

# OAuth - Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8787/auth/oauth/facebook/callback

# ============================================
# Payments
# ============================================
# Asaas (primary)
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_ENVIRONMENT=sandbox

# Stripe (secondary)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ============================================
# AI (Replicate)
# ============================================
REPLICATE_API_TOKEN=

# ============================================
# Push Notifications (OneSignal)
# ============================================
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_KEY=

# ============================================
# Storage (R2 - auto via wrangler bindings)
# ============================================
R2_VIDEOS_URL=https://videos.vfit.app.br
R2_IMAGES_URL=https://images.vfit.app.br

# ============================================
# Cloudflare Turnstile (Captcha)
# ============================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================================
# WhatsApp Gateway (Unipile) — helper scripts
# ============================================
# Token = ADMIN_AUTH_TOKEN (do Secrets Store do worker whatsapp)
WHATSAPP_GATEWAY_URL=https://whatsapp.vfit.app.br
WHATSAPP_NOTIFY_URL=https://whatsapp.vfit.app.br/task-notify
WHATSAPP_NOTIFY_TOKEN=

# Aliases aceitos por scripts (opcionais):
# WHATSAPP_ADMIN_AUTH_TOKEN=
# ADMIN_AUTH_TOKEN=

# ============================================
# Smoke Auth (QA operacional)
# ============================================
# Base da API (opcional; padrão em produção)
SMOKE_BASE_URL=https://api.vfit.app.br

# Tokens diretos
SMOKE_PERSONAL_TOKEN=
SMOKE_STUDENT_TOKEN=
SMOKE_ADMIN_TOKEN=

# Mint automático via admin (opcional)
SMOKE_MINT_PERSONAL_EMAIL=
SMOKE_MINT_PERSONAL_ID=
SMOKE_MINT_STUDENT_EMAIL=
SMOKE_MINT_STUDENT_ID=

# Ajustes operacionais
SMOKE_TEST_STUDENT_ID=
SMOKE_ALLOW_MUTATIONS=0
SMOKE_TIMEOUT_MS=15000
SMOKE_RETRIES=1
